# ============================================
# MYSignVoice - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to git (it's in .gitignore)

# --- Android SDK ---
ANDROID_SDK_PATH=C:\Users\YourUser\AppData\Local\Android\Sdk
ANDROID_NDK_VERSION=26.1.10909125

# --- OpenCV Android SDK ---
OPENCV_ANDROID_SDK_PATH=C:\path\to\opencv-android-sdk

# --- ncnn Android Prebuilt ---
NCNN_ANDROID_LIB_PATH=C:\path\to\ncnn-android-lib

# --- Python (for training scripts) ---
PYTHON_PATH=python

# --- Google Colab / Google Drive ---
GDRIVE_MODEL_PATH=/content/drive/MyDrive/sign_model

# --- App Config ---
APP_PACKAGE_NAME=com.mysignvoice.app
MIN_SDK_VERSION=24
TARGET_SDK_VERSION=34
YOLO_INPUT_SIZE=640
CONFIDENCE_THRESHOLD=0.5
NMS_IOU_THRESHOLD=0.45
NUM_CLASSES=50
